# MongoDB Connection String
# Get your free MongoDB URI from: https://www.mongodb.com/cloud/atlas
# Create a free cluster and get your connection string
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/dentalmart?retryWrites=true&w=majority

# Optional: Vercel Environment Variables
# Add MONGODB_URI to your Vercel project settings at:
# Settings → Environment Variables
